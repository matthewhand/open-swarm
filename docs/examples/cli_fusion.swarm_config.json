{
  "_comment": "Example for cli_* fusion blueprints. LLM: config profiles (under 'llm') are primary (see CONFIGURATION.md). Simple case uses OPENAI_API_KEY+OPENAI_BASE_URL (LITELLM_* compat). gpt-5.5 family. Copy cli_agents/fusion blocks into swarm_config.json.",

  "llm": {
    "default": {
      "provider": "openai",
      "model": "gpt-5.5",
      "base_url": "${OPENAI_BASE_URL}",
      "api_key": "${OPENAI_API_KEY}"
    }
  },

  "cli_agents": {
    "grok": {
      "cmd": ["grok", "-p", "{prompt}", "--output-format", "json", "--always-approve"],
      "parse": "json:.text",
      "mode": "write",
      "timeout": 240
    },
    "claude": {
      "cmd": ["claude", "-p", "{prompt}", "--output-format", "json",
              "--dangerously-skip-permissions"],
      "parse": "json:.result",
      "mode": "write",
      "timeout": 240,
      "env_allowlist": ["ANTHROPIC_API_KEY"]
    },
    "gemini": {
      "cmd": ["gemini", "-p", "{prompt}", "-o", "json", "--yolo", "--skip-trust"],
      "parse": "json:.response",
      "mode": "write",
      "timeout": 240,
      "env_allowlist": ["GEMINI_API_KEY", "GOOGLE_API_KEY"]
    },
    "codex": {
      "cmd": ["codex", "exec", "{prompt}", "--dangerously-bypass-approvals-and-sandbox"],
      "parse": "text",
      "mode": "write",
      "timeout": 240,
      "env_allowlist": ["OPENAI_API_KEY"]
    },
    "opencode": {
      "cmd": ["opencode", "run", "{prompt}", "--model", "opencode/big-pickle"],
      "parse": "text",
      "mode": "write",
      "timeout": 240
    }
  },

  "cli_fusion": {
    "default_cli": "grok",
    "default_preset": "general-high",
    "max_rounds": 1,
    "isolate_workdir": true,
    "show_analysis": false,
    "presets": {
      "general-high":   { "panel": ["grok", "claude", "gemini", "codex"], "judge": "grok" },
      "general-budget": { "panel": ["gemini"],                            "judge": "gemini" }
    }
  },

  "cli_orchestrator": {
    "router": "grok",
    "panel": ["grok", "claude", "gemini", "codex"],
    "judge": "grok"
  },

  "cli_map": {
    "planner": "grok",
    "workers": ["grok", "claude", "gemini", "codex"],
    "reducer": "grok",
    "max_items": 6
  }
}
