# =============================================================================
# Open Swarm — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values. NEVER commit your .env.
#
# What each variable does is documented in the canonical reference:
#   CONFIGURATION.md -> "Environment Variables"
#
# Security model (secure-by-default):
#   * DJANGO_DEBUG defaults to FALSE (production mode).
#   * In production mode the server REFUSES TO START unless DJANGO_SECRET_KEY,
#     DJANGO_ALLOWED_HOSTS and API_AUTH_TOKEN are all set.
#   * Development conveniences (testuser auto-login, insecure fallbacks) are
#     only honoured when DJANGO_DEBUG=true, and are off by default even then.
# =============================================================================


# =============================================================================
# SECURITY — REQUIRED IN PRODUCTION
# =============================================================================

# Django cryptographic signing key (sessions, CSRF, password resets).
# REQUIRED when DJANGO_DEBUG is not true — the server refuses to boot without it.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# WARNING: keep this secret; rotating it invalidates all sessions.
DJANGO_SECRET_KEY=""

# Debug mode. Defaults to FALSE (production).
# WARNING: NEVER set to true in production — debug mode leaks stack traces,
# settings and SQL, relaxes host checks, and enables dev-only auth fallbacks.
DJANGO_DEBUG="false"

# Comma-separated hostnames the server may be addressed as.
# REQUIRED when DJANGO_DEBUG is not true — the server refuses to boot without it.
# Example: DJANGO_ALLOWED_HOSTS="example.com,www.example.com"
DJANGO_ALLOWED_HOSTS=""

# Static bearer token required for API requests (Authorization: Bearer <token>).
# REQUIRED when DJANGO_DEBUG is not true — the server REFUSES TO START without
# it so production can never silently run with API auth disabled.
# (SWARM_API_KEY is accepted as a legacy alias if API_AUTH_TOKEN is unset.)
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_AUTH_TOKEN=""

# Comma-separated origins trusted for CSRF-protected (POST) requests.
# Default: http://localhost:8000,http://127.0.0.1:8000
# DJANGO_CSRF_TRUSTED_ORIGINS="https://example.com"


# =============================================================================
# SECURITY — DEVELOPMENT-ONLY FLAGS (never enable in production)
# =============================================================================

# Auto-login as a local 'testuser' account when normal login fails.
# Default: false. Only honoured when BOTH this flag AND DJANGO_DEBUG are true;
# the server raises ImproperlyConfigured if it is enabled outside debug mode.
# WARNING: this is an authentication bypass — development machines only.
ALLOW_TESTUSER_AUTOLOGIN="false"

# Password for the dev-only 'testuser' account. If unset, a random password is
# generated per server process (never hardcoded). Only used in debug mode.
# TESTUSER_PASSWORD=""

# Test-suite mode: CLI tools and blueprints short-circuit with canned output.
# WARNING: NEVER set in production — it disables real execution paths and
# safety checks. Intended exclusively for automated tests.
# SWARM_TEST_MODE="1"


# =============================================================================
# Core Server Configuration
# =============================================================================

HOST="0.0.0.0"
PORT="8000"
# DJANGO_SECRET_KEY: REQUIRED for production (DJANGO_DEBUG=False). Generate a strong random value.
# DJANGO_SECRET_KEY="your-strong-random-secret-key-here"
# For local dev only, can leave unset to use insecure fallback when DEBUG=True.
# SWARM_ALLOW_NO_AUTH=true : ONLY when an external layer fully gates the API
# (e.g. reverse proxy). docker-compose does NOT enable this by default.
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com : required in prod non-debug
# API_AUTH_TOKEN or SWARM_API_KEY : optional for built-in auth (else use ALLOW_NO_AUTH)

# Optional log levels
# DJANGO_LOG_LEVEL="INFO"
# SWARM_LOG_LEVEL="DEBUG"
# LOGLEVEL="INFO"


# =============================================================================
# Database Configuration
# =============================================================================

DJANGO_DATABASE="sqlite"
# Path used by the Django app (defaults to /tmp/db.sqlite3 if unset):
# DJANGO_DB_NAME="/path/to/db.sqlite3"
# Path used by SQLite-backed blueprints:
SQLITE_DB_PATH="/path/to/db.sqlite3"
# For PostgreSQL, uncomment and configure:
# POSTGRES_DB="swarm"
# POSTGRES_USER="postgres"
# POSTGRES_PASSWORD="your-postgres-password"
# POSTGRES_HOST="localhost"
# POSTGRES_PORT="5432"

# Redis (optional; used when configured)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"


# =============================================================================
# Feature Flags
# =============================================================================

# Enable the Django admin interface (true/false). Keep false unless needed.
ENABLE_ADMIN="false"

# Enable the web user interface (true/false).
ENABLE_WEBUI="false"

# Optional integrations (all default false):
# ENABLE_MCP_SERVER="false"
# ENABLE_GITHUB_MARKETPLACE="false"


# =============================================================================
# Core LLM / API Keys
# =============================================================================

OPENAI_API_KEY="your-openai-api-key"
# OPENAI_MODEL="gpt-4o"
# OPENAI_BASE_URL="https://api.openai.com/v1"
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# OLLAMA_BASE_URL="http://localhost:11434"
# LITELLM_API_KEY=""
# LITELLM_MODEL=""
# LITELLM_BASE_URL=""

# --- CLI Agent Fusion (cli_agent / cli_fusion / cli_map / cli_orchestrator) ---
# These blueprints shell out to your installed agentic CLIs, so each CLI must be
# installed AND authenticated on the host/container. Auth varies by CLI:
#   gemini  — GEMINI_API_KEY or GOOGLE_API_KEY (or `gemini` oauth login)
#   claude  — ANTHROPIC_API_KEY (above) or `claude` login
#   grok    — file-based login via the `grok`/`agent` CLI (no single env var)
#   codex   — OPENAI_API_KEY (above)
# GEMINI_API_KEY="your-gemini-api-key"
# GOOGLE_API_KEY="your-google-api-key"

# Default LLM profile when none is specified for an agent (e.g., "default")
DEFAULT_LLM="default"

# Set to true to suppress dummy API key warnings.
SUPPRESS_DUMMY_KEY="false"

# Brave Search API (used by search-capable blueprints/MCP servers)
BRAVE_API_KEY="your-brave-api-key"

# GitHub token (optional; higher rate limits for marketplace discovery)
# GITHUB_TOKEN=""


# =============================================================================
# Blueprint-Specific Environment Variables
# =============================================================================

# -- Personal Digital Assistants Blueprint --
# WEATHER_API_KEY: API key for weather information (e.g., OpenWeatherMap)
WEATHER_API_KEY="your-weather-api-key"
# QDRANT settings for Documentation Agent:
QDRANT_URL="http://your-qdrant-domain:port"
QDRANT_API_KEY="your-qdrant-api-key"

# -- Flowise Blueprint --
FLOWISE_API_KEY="your-flowise-api-key"
FLOWISE_API_ENDPOINT="http://localhost:3000"

# -- Divine Ops and Other Blueprints --
# SERPAPI_API_KEY: API key for SerpAPI search operations.
SERPAPI_API_KEY="your-serpapi-api-key"
# WP_SITES_PATH: Filesystem path for WordPress sites used in blueprints.
WP_SITES_PATH="/path/to/wp-sites.json"

# -- Miscellaneous --
# STATEFUL_CHAT_ID_PATH: JMESPath expression for stateful chat ID extraction.
STATEFUL_CHAT_ID_PATH="/default/path/to/stateful/chat_id"
# SWARM_BLUEPRINTS: Comma-separated list of blueprint names to enable.
SWARM_BLUEPRINTS="blueprint1,blueprint2"
